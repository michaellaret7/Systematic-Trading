# Copy to .env and fill in. .env is git-ignored.

# --- Alpaca (broker + live/backtest price feed) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
# true = paper trading (default/safe). Set to false ONLY for real-money live trading.
ALPACA_PAPER=true

# --- Financial Modeling Prep (fundamentals / macro enrichment) ---
FMP_API_KEY=

# --- AWS (S3 data repository + DynamoDB trade ledger) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Region hosting the DynamoDB trade-ledger table. Defaults to us-east-1 if unset.
AWS_DEFAULT_REGION=us-east-1
# S3 bucket for the data repository.
S3_BUCKET=

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=

# --- Langfuse (LLM tracing / observability) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- Lumibot runtime ---
# Disable the background telemetry emitter (stops the LUMIBOT_TELEMETRY JSON log lines).
LUMIBOT_TELEMETRY=false
